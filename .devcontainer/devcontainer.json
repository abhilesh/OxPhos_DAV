{
    "name": "OxPhos Docker Env",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "anthropic.claude-code"
            ]
        }
    },
    "remoteUser": "root",
    "postCreateCommand": "bash -c 'source ~/.bashrc'",
    "remoteEnv": {
        "ANTHROPIC_API_KEY": ""
    }
}